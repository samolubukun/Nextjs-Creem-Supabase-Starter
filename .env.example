# Supabase — get these from your Supabase project settings
# Leave as placeholder to enable Demo Mode (no external services needed)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:[PORT]/postgres

# Creem — get from Dashboard > Developers > API & Webhooks
# Test keys start with creem_test_ (auto-detected)
CREEM_API_KEY=creem_test_your-api-key
CREEM_WEBHOOK_SECRET=whsec_your-webhook-secret

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Better Stack Logging
BETTERSTACK_SOURCE_TOKEN=
BETTERSTACK_INGESTING_HOST=

# Admin Config (comma-separated for multiple admins)
ADMIN_EMAILS=admin@example.com,partner@example.com

# Creem Product IDs — create in Creem Dashboard > Commerce > Products
NEXT_PUBLIC_CREEM_STARTER_PRODUCT_ID=prod_starter
NEXT_PUBLIC_CREEM_PRO_PRODUCT_ID=prod_pro
NEXT_PUBLIC_CREEM_ENTERPRISE_PRODUCT_ID=prod_enterprise

NEXT_PUBLIC_CREEM_PRO_MAX_PRODUCT_ID=prod_W3MrXbD703JLiOAJyL6TD

# Resend (Emails)
RESEND_API_KEY=

# PostHog (Analytics)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# AI Assistant (Chatbot)
# Supported providers: openai, gemini, anthropic
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-api-key
LLM_MODEL=gpt-4o-mini

# File Storage (S3-compatible: AWS S3, Cloudflare R2, MinIO)
# S3 provider label for diagnostics only: s3 | r2 | minio
S3_PROVIDER=s3
S3_BUCKET=your-bucket
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false
S3_KEY_PREFIX=uploads
S3_PUBLIC_BASE_URL=
S3_SIGNED_URL_TTL_SECONDS=900
S3_DOWNLOAD_URL_TTL_SECONDS=300
S3_MAX_UPLOAD_BYTES=52428800
S3_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf,text/plain
